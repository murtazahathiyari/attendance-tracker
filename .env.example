# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — never commit secrets.

# Used to sign QR ID cards via HMAC-SHA256.
# Generate a long random string, e.g. `python -c "import secrets; print(secrets.token_urlsafe(48))"`
SECRET_KEY=change-me-to-a-long-random-string

# Teacher's email — where weekly reports + threshold alerts are sent.
TEACHER_EMAIL=teacher@example.com

# Gmail SMTP for sending reports.
# Use a Google "App Password" (requires 2FA on the account), NOT your regular password.
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=you@gmail.com
SMTP_PASSWORD=your-16-char-app-password

# Minimum attendance percent before a student is flagged.
MIN_ATTENDANCE_PCT=80

# Face match cosine-similarity threshold (0.0 - 1.0).
# Higher = stricter. Tune in the 0.4 - 0.6 range during testing.
FACE_MATCH_THRESHOLD=0.5

# Liveness score threshold (0.0 - 1.0).
# Default DeepFace cutoff is 0.5; we raise to 0.7 to cut false positives.
LIVENESS_THRESHOLD=0.7
